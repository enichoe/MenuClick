{
  "version": 2,
  "rewrites": [
    {
      "source": "/menu/:slug",
      "destination": "/menu.html?s=:slug"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "cleanUrls": true
}
